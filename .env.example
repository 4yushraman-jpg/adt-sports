APP_NAME="ADT Sports"
# Local dev: local / true. PRODUCTION MUST USE: APP_ENV=production, APP_DEBUG=false
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
# '*' trusts any proxy (fine when only the LB can reach the app); otherwise set the proxy CIDR
TRUSTED_PROXIES=*

LOG_CHANNEL=stack
# PRODUCTION: prefer LOG_CHANNEL=daily (or stderr in containers) and LOG_LEVEL=error
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# For MySQL, comment the line above and use:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=adt_sports
# DB_USERNAME=root
# DB_PASSWORD=

# database (default) shares state across app servers; redis for higher scale
CACHE_DRIVER=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

# Full-page response cache (guests only). Short TTL so scheduled posts surface
# promptly. Multi-node deployments: RESPONSE_CACHE_DRIVER=database (or redis).
RESPONSE_CACHE_LIFETIME=600
# PRODUCTION (HTTPS) MUST USE: SESSION_SECURE_COOKIE=true
SESSION_SECURE_COOKIE=false
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

MAIL_MAILER=log

# Error tracking (inert until a DSN is set). Get a DSN from sentry.io.
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# Seeder admin account. Set a strong password before running db:seed.
# Never commit a real value here — copy this file to .env and fill it in.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
