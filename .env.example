APP_NAME="ADT Sports"
# Local dev: local / true. PRODUCTION MUST USE: APP_ENV=production, APP_DEBUG=false
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# For MySQL, comment the line above and use:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=adt_sports
# DB_USERNAME=root
# DB_PASSWORD=

CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
# PRODUCTION (HTTPS) MUST USE: SESSION_SECURE_COOKIE=true
SESSION_SECURE_COOKIE=false
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

MAIL_MAILER=log

# Seeder admin account. Set a strong password before running db:seed.
# Never commit a real value here — copy this file to .env and fill it in.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
