APP_NAME="ADT Sports"
# Local dev: local / true. PRODUCTION MUST USE: APP_ENV=production, APP_DEBUG=false
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
# '*' trusts any proxy (fine when only the LB can reach the app); otherwise set the proxy CIDR
TRUSTED_PROXIES=*
# PRODUCTION: the single public hostname to 301 all traffic onto (apex OR www, not
# both). MUST match the host in APP_URL — the targeted page-cache invalidation
# rebuilds URLs from APP_URL, so a mismatch leaves stale pages until the TTL.
# Leave blank in local/dev to disable the redirect. e.g. CANONICAL_HOST=www.adtsports.com
CANONICAL_HOST=

LOG_CHANNEL=stack
# PRODUCTION: prefer LOG_CHANNEL=daily (or stderr in containers) and LOG_LEVEL=error
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# For MySQL, comment the line above and use:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=adt_sports
# DB_USERNAME=root
# DB_PASSWORD=

# database (default) shares state across app servers; redis for higher scale
CACHE_DRIVER=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

# Full-page response cache (guests only). Short TTL so scheduled posts surface
# promptly. Multi-node deployments: RESPONSE_CACHE_DRIVER=database (or redis).
RESPONSE_CACHE_LIFETIME=600
# PRODUCTION (HTTPS) MUST USE: SESSION_SECURE_COOKIE=true
SESSION_SECURE_COOKIE=false
# Confirmation/newsletter mail is a queued job (App\Mail\CommenterConfirmation
# implements ShouldQueue). Keep this OFF the request path: use 'database' (jobs
# table already migrated) or 'redis', and run a worker:
#   php artisan queue:work --tries=3 --backoff=60 --max-time=3600
# 'sync' runs jobs inline and re-introduces the blocking mail send — dev only.
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

# Email (subscribe-to-comment confirmation + newsletter). Local dev can use 'log'
# (writes the email + confirm link to storage/logs/laravel.log). PRODUCTION: 'resend'.
MAIL_MAILER=log
RESEND_API_KEY=
# Use onboarding@resend.dev until your domain is verified in Resend, then switch
# to noreply@<your-verified-domain>.
MAIL_FROM_ADDRESS=onboarding@resend.dev
MAIL_FROM_NAME="ADT Sports"

# Error tracking (inert until a DSN is set). Get a DSN from sentry.io.
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# Seeder admin account. Set a strong password before running db:seed.
# Never commit a real value here — copy this file to .env and fill it in.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
